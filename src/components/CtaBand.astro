---
import Button from './Button.astro';

interface Props {
  title?: string;
  micro?: string;
}
const { title = 'Prêt à voir VAGA en action ?', micro = '15 minutes · sans engagement · réponse sous 24h' } =
  Astro.props;
---

<section class="py-24 text-center">
  <div class="container-site">
    <h2 class="h2">{title}</h2>
    <div class="mt-7 flex flex-wrap justify-center gap-3.5">
      <Button href="/demo" size="lg" arrow>Demander une démo</Button>
    </div>
    <p class="mt-3.5 text-[13.5px] text-muted">{micro}</p>
  </div>
</section>
