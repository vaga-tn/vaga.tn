---
interface Props {
  size?: number;
  class?: string;
}
const { size = 15, class: extra = '' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 16 16"
  fill="none"
  aria-hidden="true"
  class={extra}
>
  <path
    d="M3 8.5 6.5 12 13 4.5"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
</svg>
