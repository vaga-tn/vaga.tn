---
// Light/dark toggle — behavior per .ai/website/design-system.md §10:
// override in localStorage only when it differs from the OS preference.
---

<button
  id="theme-toggle"
  type="button"
  class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-line text-ink transition-[border-color] duration-150 hover:border-line-strong"
  aria-label="Changer de thème"
>
  <svg data-icon="moon" width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
    <path
      d="M17 11.5A7 7 0 0 1 8.5 3 7 7 0 1 0 17 11.5z"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linejoin="round"></path>
  </svg>
  <svg data-icon="sun" class="hidden" width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
    <circle cx="10" cy="10" r="3.5" stroke="currentColor" stroke-width="1.6"></circle>
    <path
      d="M10 2.5v2 M10 15.5v2 M2.5 10h2 M15.5 10h2 M4.7 4.7l1.4 1.4 M13.9 13.9l1.4 1.4 M15.3 4.7l-1.4 1.4 M6.1 13.9l-1.4 1.4"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"></path>
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle')!;
  const root = document.documentElement;
  const mq = window.matchMedia('(prefers-color-scheme: dark)');

  const effective = () => root.dataset.theme ?? (mq.matches ? 'dark' : 'light');

  const render = () => {
    const dark = effective() === 'dark';
    btn.setAttribute('aria-label', dark ? 'Activer le thème clair' : 'Activer le thème sombre');
    btn.querySelector('[data-icon="sun"]')!.classList.toggle('hidden', !dark);
    btn.querySelector('[data-icon="moon"]')!.classList.toggle('hidden', dark);
  };

  btn.addEventListener('click', () => {
    const next = effective() === 'dark' ? 'light' : 'dark';
    const os = mq.matches ? 'dark' : 'light';
    try {
      if (next === os) {
        delete root.dataset.theme;
        localStorage.removeItem('theme');
      } else {
        root.dataset.theme = next;
        localStorage.theme = next;
      }
    } catch {
      root.dataset.theme = next;
    }
    render();
  });

  mq.addEventListener('change', render);
  render();
</script>
