---
import Button from "../Button.astro";
---

<section class="pt-24 text-center">
  <div class="container-site space-y-4">
    <div class="flex flex-wrap justify-center gap-4" aria-hidden="true">
      <span class="doodle -rotate-4">Devis → Facture ✓</span>
      <span class="doodle rotate-2.5 border-dashed shadow-none">
        Stock à jour ✓
      </span>
      <span class="doodle -rotate-1.5">TEIF ✓</span>
    </div>

    <h1 class="h1">
      L'ERP qui gère votre entreprise,<br />
      <span class="squiggle relative whitespace-nowrap">
        du devis à l'encaissement.
        <svg viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true">
          <path
            d="M4 8 Q 40 2 75 7 T 150 7 T 225 7 T 296 6"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"></path>
        </svg>
      </span>
    </h1>

    <p class="mx-auto max-w-160 text-lg text-body">
      Devis, commandes, bons de livraison, factures, stock multi-entrepôt et
      trésorerie — dans un seul logiciel pensé pour les PME tunisiennes.
      Conforme à la facturation électronique TEIF dès le départ.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <Button href="/demo" size="lg" arrow>Demander une démo</Button>
      <Button href="/tarifs" size="lg" variant="ghost">Voir les tarifs</Button>
    </div>

    <p class="text-base text-muted">15 minutes · sans engagement</p>

    <div
      class="mx-auto overflow-hidden shadow-md"
      aria-label="Aperçu de l'interface VAGA: écran d'accueil avec la grille des applications"
    >
      <img src="vaga_ui_screenshot.png" alt="VAGA preview" />
    </div>
  </div>
</section>

<style>
  .doodle {
    border: 1.5px solid var(--ink);
    border-radius: 12px;
    background: var(--page);
    padding: 8px 14px;
    font-size: 14px;
    font-weight: 600;
    box-shadow: 3px 3px 0 var(--ink);
  }
  .doodle.shadow-none {
    box-shadow: none;
  }
  .squiggle svg {
    position: absolute;
    left: 0;
    bottom: -10px;
    width: 100%;
    height: 12px;
  }
</style>
