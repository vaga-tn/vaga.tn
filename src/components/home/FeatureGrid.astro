---
import { getCollection } from "astro:content";
import { featureIcons } from "../../lib/feature-icons";

const features = (await getCollection("features")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="fonctionnalites" class="py-8">
  <div class="container-site">
    <h2 class="h2">Un module pour chaque partie<br />de votre activité</h2>
    <div class="mt-11 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="flex flex-col gap-2.5 rounded-[14px] border border-line bg-page p-6 transition-[border-color] duration-150 hover:border-line-strong">
            <span
              class="mb-1 flex h-10 w-10 items-center justify-center rounded-[9px] border border-line-strong text-ink"
              set:html={featureIcons[f.id]}
            />
            <h3 class="text-lg font-bold tracking-[-0.01em]">
              {f.data.card.title}
            </h3>
            <p class="text-[14.5px] text-body">{f.data.card.benefit}</p>
            <a
              href={`/fonctionnalites/${f.id}`}
              class="mt-auto pt-1.5 text-[13.5px] font-semibold text-ink no-underline hover:underline"
            >
              En savoir plus →
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
