---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import Button from '../components/Button.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import CtaBand from '../components/CtaBand.astro';

interface Props {
  feature: CollectionEntry<'features'>;
}
const { feature } = Astro.props;
const { data } = feature;
---

<Base title={data.metaTitle} description={data.metaDescription}>
  <section class="pb-16 pt-24 text-center">
    <div class="container-site">
      <h1 class="h1 mx-auto max-w-[820px]">{data.title}</h1>
      <p class="mx-auto mt-5 max-w-[640px] text-lg text-body">{data.subhead}</p>
      <div class="mt-8 flex justify-center">
        <Button href="/demo" size="lg" arrow>Demander une démo</Button>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-site max-w-[820px]">
      <h2 class="h2">Fonctionnement</h2>
      <ul class="mt-8 flex list-none flex-col gap-0">
        {
          data.fonctionnement.map((item) => (
            <li class="border-b border-line py-5 first:border-t">
              <span class="font-bold text-ink">{item.label}</span>
              <span class="text-body"> — {item.text}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-site max-w-[820px]">
      <div class="rounded-[14px] border-[1.5px] border-line-strong px-7 py-7">
        <h2 class="text-lg font-bold tracking-[-0.01em]">Pourquoi VAGA</h2>
        <p class="mt-2.5 text-[15px] text-body">{data.pourquoi}</p>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-site max-w-[820px]">
      <h2 class="mb-4 text-xs font-semibold uppercase tracking-[.07em] text-muted">Modules liés</h2>
      <div class="flex flex-wrap gap-2.5">
        {
          data.related.map((rel) => (
            <a
              href={rel.href}
              class="rounded-full border border-line px-4 py-2 text-sm font-semibold text-ink no-underline transition-[border-color] duration-150 hover:border-line-strong"
            >
              {rel.label} →
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-4">
    <div class="container-site">
      <h2 class="h2 text-center">Questions fréquentes</h2>
      <FaqAccordion items={data.faq} class="mt-11" />
    </div>
  </section>

  <CtaBand />
</Base>
