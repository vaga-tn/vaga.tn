---
import Base from "../../layouts/Base.astro";
import CtaBand from "../../components/CtaBand.astro";
import { getAllPosts, formatPostDate, coverImageUrl } from "../../lib/contentful";

const posts = await getAllPosts();
---

<Base
  title="Blog | VAGA ERP — Conseils de gestion pour PME tunisiennes"
  description="Articles, guides et conseils pratiques sur la gestion d'entreprise, la facturation et l'ERP pour les PME en Tunisie."
>
  <section class="border-b border-line pb-14 pt-24">
    <div class="container-site">
      <p class="mb-2 text-xs font-semibold uppercase tracking-[.1em] text-muted">
        Ressources
      </p>
      <h1 class="h1">Blog VAGA</h1>
      <p class="mt-4 max-w-xl text-lg text-body">
        Conseils pratiques sur la gestion d'entreprise, l'ERP et la digitalisation
        pour les PME tunisiennes.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="container-site">
      {
        posts.length === 0 ? (
          <div class="py-24 text-center text-muted">
            <p class="text-lg font-medium">Aucun article pour l'instant.</p>
            <p class="mt-1 text-sm">Revenez bientôt - du contenu arrive.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => {
              const { title, slug, excerpt, publishedDate, tags } = post.fields;
              const imageUrl = coverImageUrl(post);
              return (
                <a
                  href={`/ressources/${slug}`}
                  class="group flex flex-col overflow-hidden rounded-[14px] border border-line bg-page no-underline transition-[border-color] duration-150 hover:border-line-strong"
                >
                  <div class="aspect-video overflow-hidden border-b border-line bg-fill">
                    {imageUrl ? (
                      <img
                        src={imageUrl}
                        alt={title}
                        width="640"
                        height="360"
                        loading="lazy"
                        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center">
                        <span class="text-3xl font-extrabold tracking-[-0.04em] text-muted opacity-40">
                          vaga
                        </span>
                      </div>
                    )}
                  </div>
                  <div class="flex flex-1 flex-col gap-3 p-5">
                    {Array.isArray(tags) && tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {tags.map((tag) => (
                          <span class="rounded-full border border-line px-2.5 py-0.5 text-xs font-medium text-muted">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                    <h2 class="text-base font-bold leading-snug tracking-[-0.01em] text-ink">
                      {title}
                    </h2>
                    {excerpt && (
                      <p class="line-clamp-3 flex-1 text-sm leading-relaxed text-body">
                        {excerpt}
                      </p>
                    )}
                    <time class="mt-auto text-xs text-muted">
                      {formatPostDate(publishedDate)}
                    </time>
                  </div>
                </a>
              );
            })}
          </div>
        )
      }
    </div>
  </section>

  <CtaBand />
</Base>
